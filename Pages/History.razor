@page "/history"
@using BloodPressureTracker.Models
@using BloodPressureTracker.Services
@inject BloodPressureService BPService
@inject IJSRuntime JS

<PageTitle>History - Blood Pressure Tracker</PageTitle>

<div class="history-container">
    <h1 class="page-title">Blood Pressure History</h1>

    @if (readings == null)
    {
        <p class="loading">Loading...</p>
    }
    else if (readings.Count == 0)
    {
        <div class="empty-state">
            <p>No blood pressure readings recorded yet.</p>
            <a href="/" class="btn btn-primary">Add First Reading</a>
        </div>
    }
    else
    {
        <div class="history-stats">
            <div class="stat-card">
                <div class="stat-value">@readings.Count</div>
                <div class="stat-label">Total Readings</div>
            </div>
            <div class="stat-card">
                <div class="stat-value">@CalculateAverageSystolic()</div>
                <div class="stat-label">Avg Systolic</div>
            </div>
            <div class="stat-card">
                <div class="stat-value">@CalculateAverageDiastolic()</div>
                <div class="stat-label">Avg Diastolic</div>
            </div>
        </div>

        <div class="history-table-container">
            <table class="history-table">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Time</th>
                        <th>Blood Pressure</th>
                        <th>Notes</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var reading in readings.OrderByDescending(r => r.Date).ThenByDescending(r => r.TimeOfDay))
                    {
                        <tr>
                            <td>@reading.Date.ToString("MMM dd, yyyy")</td>
                            <td>@reading.TimeOfDay</td>
                            <td class="bp-value">
                                <span class="systolic">@reading.Systolic</span>/<span class="diastolic">@reading.Diastolic</span>
                            </td>
                            <td class="notes-cell">@reading.Notes</td>
                            <td>
                                <button class="btn-icon" @onclick="() => DeleteReading(reading.Id)" title="Delete">
                                    🗑️
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="action-buttons">
            <button class="btn btn-secondary" @onclick="ClearAllData">Clear All Data</button>
        </div>
    }
</div>

@code {
    private List<BloodPressureReading>? readings;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        readings = await BPService.GetAllReadingsAsync();
    }

    private async Task DeleteReading(Guid id)
    {
        bool confirmed = await JS.InvokeAsync<bool>("confirm", "Are you sure you want to delete this reading?");
        if (confirmed)
        {
            await BPService.DeleteReadingAsync(id);
            await LoadData();
        }
    }

    private async Task ClearAllData()
    {
        bool confirmed = await JS.InvokeAsync<bool>("confirm", "Are you sure you want to delete ALL readings? This cannot be undone.");
        if (confirmed)
        {
            await BPService.ClearAllDataAsync();
            await LoadData();
        }
    }

    private string CalculateAverageSystolic()
    {
        if (readings == null || readings.Count == 0) return "N/A";
        var avg = readings.Where(r => r.Systolic.HasValue).Average(r => r.Systolic!.Value);
        return avg.ToString("F0");
    }

    private string CalculateAverageDiastolic()
    {
        if (readings == null || readings.Count == 0) return "N/A";
        var avg = readings.Where(r => r.Diastolic.HasValue).Average(r => r.Diastolic!.Value);
        return avg.ToString("F0");
    }
}
